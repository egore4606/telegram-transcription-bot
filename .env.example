TELEGRAM_TOKEN=your_telegram_bot_token
GEMINI_API_KEY=your_primary_gemini_api_key
GEMINI_API_KEY_2=your_backup_gemini_api_key # резервный ключ (опционально)
GEMINI_MODEL=gemini-3.1-flash-lite-preview # опционально, стартовая модель
MODEL_REQUEST_TIMEOUT=45           # опционально, таймаут одной попытки Gemini в секундах
DATABASE_PATH=/data/bot.sqlite3    # опционально, путь к SQLite базе
ADMIN_USER_ID=123456789            # твой Telegram ID (для /stats), узнай через /myid
