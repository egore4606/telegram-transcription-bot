# Required credentials
TELEGRAM_TOKEN=your_telegram_bot_token
GEMINI_API_KEY=your_primary_gemini_api_key

# Optional backup credential
GEMINI_API_KEY_2=

# Gemini models and retry behavior
GEMINI_MODEL=gemini-3.5-flash
MODEL_REQUEST_TIMEOUT=40
PRIMARY_MODEL_ATTEMPTS=1
FALLBACK_MODEL_ATTEMPTS=1

# Persistent storage and administrator
DATABASE_PATH=/data/bot.sqlite3
ADMIN_USER_ID=123456789

# Media and command limits
RATE_LIMIT=5
COMMAND_RATE_LIMIT=10
COMMAND_RATE_LIMIT_WINDOW_SECONDS=300
MAX_ACTIVE_JOBS_PER_USER=3
MAX_ACTIVE_JOBS_PER_CHAT=5
PENDING_FEEDBACK_TTL_SECONDS=900

# Progress-message refresh intervals in seconds
PROGRESS_PRIVATE_REFRESH_INTERVAL=1
PROGRESS_GROUP_REFRESH_INTERVAL=5
